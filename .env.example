# LangSmith (required for tracing + evaluation)
LANGSMITH_API_KEY=ls__your_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=greenwashing-detector
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Model provider config
# Options: "ollama" (default) or "huggingface" (fallback)
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_JUDGE_MODEL=llama3.2:3b

# HuggingFace fallback settings
HF_MODEL=meta-llama/Llama-3.2-1B-Instruct
HF_JUDGE_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Runtime
MAX_RETRIES=2
LOG_LEVEL=INFO
